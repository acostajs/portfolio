echo "🔍 Running pre-commit validation (Formatting & Type-checks)..."

# 1. Run lint-staged to handle auto-formatting and surgical checks on staged files
# This will run ruff (fix/format) for backend and prettier/eslint for frontend
bunx lint-staged

# 2. Run full project type-checking to ensure no regressions
# This is mandatory and the commit will fail if these do not pass
echo "✅ Type-checking Frontend..."
cd frontend && bun tsc --noEmit
echo "✅ Type-checking Backend..."
cd backend && uv run pyright

echo "🚀 All checks passed. Proceeding with commit."
